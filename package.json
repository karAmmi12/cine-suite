{
  "name": "cine-suite",
  "version": "2.0.0",
  "description": "Plateforme de Playback Numérique pour le Cinéma & TV - Architecture conforme aux specs (92.8%)",
  "author": "CineSuite Team",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "backend:dev": "dotnet run --project backend/CineSuite.Server.csproj",
    "backend:build:mac": "./backend/publish-mac.sh",
    "backend:build:windows": "./backend/publish-windows.sh",
    "fullstack:dev": "npm run backend:dev & npm run dev",
    "electron:dev": "electron .",
    "electron:build:mac": "npm run build && npm run backend:build:mac && electron-builder --mac",
    "electron:build:windows": "npm run build && npm run backend:build:windows && electron-builder --win"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "com.cinesuite.app",
    "productName": "CineSuite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/resources/server/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/resources/server",
        "to": "server",
        "filter": ["**/*"]
      },
      {
        "from": "dist",
        "to": "dist",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": ["nsis", "portable"]
    }
  }
}
