# 🔐 Configuration Sécurité CineSuite
# NE PAS COMMITER CE FICHIER (.gitignore)

# === SUPABASE (Option 1 - Recommandé) ===
# 1. Va sur https://supabase.com
# 2. Crée un projet
# 3. Copie l'URL et l'anon key (Settings → API)

VITE_SUPABASE_URL=https://votreprojet.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URLs des endpoints (auto-générés après deploy Supabase)
VITE_TELEMETRY_URL=https://votreprojet.supabase.co/functions/v1/telemetry
VITE_SECURITY_URL=https://votreprojet.supabase.co/functions/v1/security-report

# === CUSTOM BACKEND (Option 2) ===
# Si tu as ton propre backend :
# VITE_TELEMETRY_URL=https://ton-api.com/telemetry
# VITE_SECURITY_URL=https://ton-api.com/security/report

# === DISCORD ALERTS (Optionnel) ===
# Pour recevoir les alertes critiques sur Discord
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456/abcdef...

# === MODE DEBUG ===
# En dev, tous les logs sont affichés en console
# En production, tout est envoyé au backend
